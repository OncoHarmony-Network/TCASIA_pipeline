# TCASIA Pipeline Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# Directory Paths
# ============================================

# Root directory for RNA-seq data
ROOT_DIR=/path/to/your/data

# Raw FASTQ files directory
RAW_DIR=${ROOT_DIR}/fastq

# Aligned BAM files directory
BAM_DIR=${ROOT_DIR}/aligned

# Working directory for outputs
WORKDIR=${ROOT_DIR}/AS_output

# ============================================
# Reference Files
# ============================================

# STAR index directory (GRCh38 + GENCODE v34)
STAR_INDEX_DIR=/path/to/references/STAR_index

# Reference genome FASTA
REF_FA=/path/to/references/GRCh38.primary_assembly.genome.fa

# GENCODE GTF annotation
REF_GTF=/path/to/references/gencode.v34.annotation.gtf

# GENCODE GFF3 annotation (for MAJIQ)
REF_GFF=/path/to/references/gencode.v34.annotation.gff3

# Salmon index directory
SALMON_INDEX=/path/to/references/gencode.v34.transcripts.salmon.index

# SUPPA2 events file
SUPPA2_EVENTS=/path/to/references/gencode.v34.events.ioe

# ============================================
# MAJIQ License
# ============================================

# Path to MAJIQ academic license file
# Obtain from: https://majiq.biociphers.org/
MAJIQ_LICENSE=/path/to/majiq_license_academic_official.lic

# ============================================
# Sequencing Parameters
# ============================================

# Cohort/Project name
COHORT=your_cohort_name

# Library strandness (options: fr-firststrand, fr-secondstrand, unstranded)
# Use RSeQC infer_experiment to determine
STRANDNESS=fr-firststrand

# Maximum read length (use maximum if variable)
# Run scripts/read_length.sh to determine
READ_LEN=150

# ============================================
# Computational Resources
# ============================================

# Number of CPU cores for parallel processing
THREADS=16

# Maximum memory (GB) for STAR alignment
MAX_MEMORY=32
