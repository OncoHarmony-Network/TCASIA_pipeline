from collections import defaultdict
import tempfile


import os
import glob

# 获取样本列表
raw_DIR = config["raw_DIR"]
bam_DIR = config["bam_DIR"]
workdir: config['workdir']

def get_samples():
    return [os.path.splitext(os.path.basename(x))[0].split('_')[0] for x in glob.glob(f"{raw_DIR}/*_1.fastq.gz")]

samples = get_samples()

temp_dir = tempfile.TemporaryDirectory()

rule rmats:
    input:
        expand("AS_output/{sample}/rmats/", sample=samples),

rule rmats_create_input:
    input:
        bam=lambda wildcards: f"{config['bam_DIR']}/{wildcards.sample}/{wildcards.sample}_Aligned.sortedByCoord.out.bam",
    log:
        "logs/rmats_create_input_{sample}.log",
    output:
        txt="rmats/{sample}.txt",
    run:
      with open(output.txt, "w") as fou:
            fou.write(input.bam)

rule rmats_run:
    input:
        alt="rmats/{sample}.txt",
    output:
        directory("AS_output/{sample}/rmats/"),
    conda:
        "rmats",
    log:
        "logs/rmats_run_{sample}.log"
    params:
        gtf=config["ref"],
        lib=config.get("strandness", "fr-unstranded"),
        read_len=config["read_len"],
        allow_clipping=config.get("rmats_allow_clipping", "--allow-clipping"),
        variable_read_length=config.get(
            "rmats_variable_read_length", "--variable-read-length"
        ),
        novel_ss=config.get("rmats_novel_ss", "--novelSS"),
        extra=config.get("rmats_extra", ""),
        tmp=os.path.join(temp_dir.name, "{sample}/"),
    shell:
        "rmats.py "
        "--b1 {input.alt} "
        "--gtf {params.gtf} "
        "--readLength {params.read_len} "
        "--nthread 30 "
        "--od {output} "
        "-t paired "
        "--cstat 0.0001 "
        "--tmp {params.tmp} "
        "--variable-read-length "

